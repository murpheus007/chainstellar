---
interface Props {
	title?: string;
	description?: string;
}

const { 
	title = "Chainstellar – Portfolio", 
	description = "Creative Writer & Technical Analyst in the blockchain ecosystem" 
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<meta charset="UTF-8" />
<link
   rel="icon"
   type="image/png"
   href={new URL('/favicon.png?v=1', Astro.site)} />
<link
   rel="shortcut icon"
   type="image/png"
   href={new URL('/favicon.png?v=1', Astro.site)} />
<link
   rel="apple-touch-icon"
   href={new URL('/favicon.png?v=1', Astro.site)} />
<meta
   name="viewport"
   content="width=device-width, initial-scale=1.0" />
<meta name="color-scheme" content="light dark" />

<script is:inline>
   function applyTheme() {
      const theme = (() => {
         if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
            return localStorage.getItem('theme');
         }
         return 'light';
      })();
   
      if (theme === 'dark') {
         document.documentElement.classList.add('dark');
         document.documentElement.setAttribute('data-theme', 'dark');
      } else {
         document.documentElement.classList.remove('dark');
         document.documentElement.setAttribute('data-theme', 'light');
      }
      
      // We don't force save it unless the user toggles it manually in the UI
      // to avoid overwhelming their choice if they change system settings.
   }

   applyTheme();
</script>

<title>{title}</title>
<link rel="canonical" href={canonicalURL} />
<meta
   name="description"
   content={description} />
<meta
   name="keywords"
   content="Chainstellar, portfolio, blockchain writer, technical analyst, web3 creator" />
<meta
   name="author"
   content="Damian D. Chidera" />

<meta
   property="og:title"
   content={title} />
<meta
   property="og:description"
   content={description} />
<meta
   property="og:image"
   content={new URL('/preview.png?v=1', Astro.site)} />
<meta
   property="og:url"
   content={canonicalURL} />
<meta
   property="og:type"
   content="website" />

<meta
   name="twitter:card"
   content="summary_large_image" />
<meta
   name="twitter:title"
   content={title} />
<meta
   name="twitter:description"
   content={description} />
<meta
   name="twitter:image"
   content={new URL('/preview.png?v=1', Astro.site)} />
<meta
   name="google-site-verification"
   content="u4vMAOmSiJye3bBNcTl0xAbge191d7F52Mbw-it04gc" />
